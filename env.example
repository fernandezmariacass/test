# ============================================================
# .env.example — Copy to .env and fill in real values.
# ⚠️  NEVER commit .env to version control.
# ============================================================

# Flask
FLASK_ENV=development
SECRET_KEY=REPLACE_WITH_LONG_RANDOM_SECRET_KEY

# Database
# SQLite (default): leave empty
# PostgreSQL: postgresql://user:password@host/dbname
DATABASE_URL=

# ── Allow-list ─────────────────────────────────────────────
# Comma-separated IPs that can access the system
ALLOWED_IPS=127.0.0.1,::1
# CIDR ranges (set in instance/config.py as ALLOWED_NETWORKS list)

# ── Default admin (change IMMEDIATELY after first run) ─────
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!

# ── Camera ─────────────────────────────────────────────────
# 0 = first webcam, or use an RTSP URL:
# CAMERA_SOURCE=rtsp://user:password@192.168.1.100:554/stream
CAMERA_SOURCE=0
CAMERA_FPS=15
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720

# ── Notifications: Email ───────────────────────────────────
NOTIFY_EMAIL_ENABLED=false
NOTIFY_FROM_EMAIL=alerts@yourdomain.com
NOTIFY_TO_EMAIL=admin@yourdomain.com

# Option A: Resend API (preferred)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Option B: SMTP fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.gmail@gmail.com
SMTP_PASSWORD=your_app_password_here

# ── Notifications: Telegram ────────────────────────────────
NOTIFY_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ── Rate limiting ──────────────────────────────────────────
# Max failed login attempts per IP in a 10-minute window
LOGIN_RATE_LIMIT=5
